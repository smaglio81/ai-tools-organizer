    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsix": "npx vsce package",
    "install:vsix": "npx vsce package && node -e \"const fs=require('fs'); const files=fs.readdirSync('.').filter(f=>f.startsWith('agent-organizer-')&&f.endsWith('.vsix')).sort(); if(files.length) require('child_process').execSync('code-insiders --install-extension '+files[files.length-1], {stdio:'inherit'});\"",
    "uninstall:vsix": "code-insiders --uninstall-extension smaglio81.agent-organizer",
    "install:vsix:kiro": "npx vsce package && node -e \"const fs=require('fs'); const files=fs.readdirSync('.').filter(f=>f.startsWith('agent-organizer-')&&f.endsWith('.vsix')).sort(); if(files.length) require('child_process').execSync('kiro --install-extension '+files[files.length-1], {stdio:'inherit'});\"",
    "uninstall:vsix:kiro": "kiro --uninstall-extension smaglio81.agent-organizer",
    "reinstall:vsix": "npm run uninstall:vsix && npm run install:vsix",
    "reinstall:vsix:kiro": "npm run uninstall:vsix:kiro && npm run install:vsix:kiro",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vscode-test"

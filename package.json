{
  "name": "agent-organizer",
  "displayName": "Agent Organizer",
  "description": "AI Tool Organizer and Marketplace",
  "version": "0.0.8",
  "icon": "resources/logo.png",
  "publisher": "smaglio81",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "agent",
    "skills",
    "marketplace",
    "ai",
    "claude"
  ],
  "bugs": {
    "url": "https://github.com/smaglio81/agent-organizer/issues",
    "email": "smaglio81@gmail.com"
  },
  "homepage": "https://github.com/smaglio81/agent-organizer/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaglio81/agent-organizer.git"
  },
  "activationEvents": [
    "onView:agentOrganizer.marketplace",
    "onView:agentOrganizer.skills"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-organizer",
          "title": "Agent Organizer",
          "icon": "resources/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "agent-organizer": [
        {
          "id": "agentOrganizer.marketplace",
          "name": "Marketplace",
          "icon": "resources/activity-bar-icon.svg"
        },
        {
          "id": "agentOrganizer.agents",
          "name": "Agents",
          "icon": "resources/agents-icon.svg"
        },
        {
          "id": "agentOrganizer.hooksGithub",
          "name": "Hooks - GitHub",
          "icon": "resources/hooks-icon.svg"
        },
        {
          "id": "agentOrganizer.hooksKiro",

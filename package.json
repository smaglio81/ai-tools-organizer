      },
      {
        "view": "agentOrganizer.agents",
        "contents": "Loading ...",
        "when": "!agentOrganizer.agents:initialScanComplete"
      },
      {
        "view": "agentOrganizer.agents",
        "contents": "No agents found.",
        "when": "agentOrganizer.agents:initialScanComplete"
      },
      {
        "view": "agentOrganizer.hooksGithub",
        "contents": "Loading ...",
        "when": "!agentOrganizer.hooksGithub:initialScanComplete"
      },
      {
        "view": "agentOrganizer.hooksGithub",
        "contents": "No GitHub hooks found.",
        "when": "agentOrganizer.hooksGithub:initialScanComplete"
      },
      {
        "view": "agentOrganizer.hooksKiro",
        "contents": "Loading ...",
        "when": "!agentOrganizer.hooksKiro:initialScanComplete"
      },
      {
        "view": "agentOrganizer.hooksKiro",

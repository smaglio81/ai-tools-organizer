          "icon": "resources/prompts-icon.svg"
        },
        {
          "id": "agentOrganizer.skills",
          "name": "Skills",
          "icon": "resources/skills-icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentOrganizer.skills",
        "contents": "Loading ...",
        "when": "!agentOrganizer:initialScanComplete"
      },
      {
        "view": "agentOrganizer.skills",
        "contents": "No skills installed yet.\n[Browse Marketplace](command:agentOrganizer.focusMarketplace)",

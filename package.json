              "repo": "agent-skill-code-runner",
              "branch": "main"
            },
            {
              "owner": "iamaanahmad",
              "repo": "everything-kiro-ide",
              "branch": "main"
            },
            {
              "owner": "microsoftdocs",
              "repo": "mcp",
              "branch": "main"
            },
            {
              "owner": "openai",
              "repo": "skills",
              "branch": "main"
            },
            {
              "owner": "pytorch",
              "repo": "pytorch",
              "branch": "main"
            }
          ],
          "markdownDescription": "GitHub repositories to fetch content from. Use the **Add Repository** button in the Marketplace view to add repos from a GitHub URL.",
          "items": {
            "type": "object",
            "properties": {
              "owner": {
                "type": "string",
                "description": "GitHub repository owner"
              },
              "repo": {
                "type": "string",
                "description": "GitHub repository name"
              },
              "branch": {
                "type": "string",
                "default": "main",
                "description": "Branch name"
              }
            }
          }
        },
        "agentOrganizer.installLocations": {
          "type": "object",
          "default": {
            "agents": "~/.copilot/agents",
            "hooksGithub": "~/.copilot/hooks",
            "hooksKiro": ".kiro/hooks",
            "instructions": "~/.copilot/instructions",
            "plugins": "~/.copilot/plugins",
            "prompts": "~/.copilot/prompts",
            "skills": "~/.copilot/skills"
          },
          "description": "Per-area default download locations. Keys are area identifiers (agents, hooksGithub, hooksKiro, instructions, plugins, prompts, skills). Values are path strings.",
          "properties": {
            "agents": { "type": "string", "description": "Default download location for agents" },
            "hooksGithub": { "type": "string", "description": "Default download location for GitHub hooks" },
            "hooksKiro": { "type": "string", "description": "Default download location for Kiro hooks" },
            "instructions": { "type": "string", "description": "Default download location for instructions" },
            "plugins": { "type": "string", "description": "Default download location for plugins" },
            "prompts": { "type": "string", "description": "Default download location for prompts" },
            "skills": { "type": "string", "description": "Default download location for skills" }
          },
          "additionalProperties": false
        },
        "agentOrganizer.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub personal access token for higher API rate limits (optional)",
          "scope": "application"
        },
        "agentOrganizer.cacheTimeout": {
          "type": "number",
          "default": 3600,
          "description": "Cache timeout for marketplace data in seconds"
        }
      }
    }

      {
        "view": "agentOrganizer.prompts",
        "contents": "Loading ...",
        "when": "!agentOrganizer.prompts:initialScanComplete"
      },
      {
        "view": "agentOrganizer.prompts",
        "contents": "No prompts found.",
        "when": "agentOrganizer.prompts:initialScanComplete"
      }
